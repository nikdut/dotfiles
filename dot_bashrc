#
# ~/.bashrc
# chezmoi

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

#pstarship prompt
# 
eval "$(starship init bash)"

alias vi='vim'

alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias td='todo.sh'
PS1='[\u@\h \W]\$ '
export EDITOR=vim
# vim bindings for bash
set -o vi
# zoxide setup
eval "$(zoxide init bash)"
# fzf setup
eval "$(fzf --bash)"
# alias to search with fzf and open with vim
alias fz='rg --files --hidden --follow --ignore-vcs -g "!{node_modules,.git}"|fzf'
alias fv='vim $(fz)'
# workaround for cheznav
alias cn='cheznavworkaround'
cheznavworkaround() {
eval "$(ssh-agent -s)"
ssh-add ~/.ssh/id_ed25519  
cheznav
}
#alias to listen to music
alias mmpv='mpv --idle http://192.168.1.19:8000'
# alias to search yay with fzf
alias fy='fzfyay'
fzfyay() {
  local pkg
  pkg=$(yay -Slq | fzf -m --preview 'yay -Si {1} 2>/dev/null || echo "No info available"' --preview-window=right:50%:wrap)
  if [ -n "$pkg" ]; then
    echo "Installing: $pkg"
    yay -S $pkg
  fi
}
# chezmoi pusher
# Function to push chezmoi dotfiles to GitHub with a custom commit message
cheztoi() {
    # Navigate to chezmoi directory
    cd ~/.local/share/chezmoi/ || {
        echo "Error: chezmoi directory not found at ~/.local/share/chezmoi/"
        return 1
    }

    # Check if there are changes to commit
    if git diff-index --quiet HEAD --; then
        echo "No changes to commit in chezmoi."
        return 0
    fi

    # Prompt for commit message
    read -p "Enter commit message for chezmoi dotfiles: " commit_msg

    # Exit if no message is provided
    if [[ -z "$commit_msg" ]]; then
        echo "No commit message provided. Aborting."
        return 1
    fi

    # Add all changes, commit, and push
    git add . && \
    git commit -m "$commit_msg" && \
    git push origin master

    # Return to the original directory
    cd - > /dev/null
}

# chezmoi helper
alias chezit='chezmoi managed |fzf | xargs -r chezmoi edit'

